{
  "adapter": "mothership",
  "adapter_version": "0.1.0",
  "validation": {
    "field_values": {
      "visibility": ["warden", "players", "shared"],
      "warden_only": ["true", "false"]
    },
    "forbidden_combinations": [
      {"visibility": "players", "warden_only": "true"}
    ]
  },
  "legacy_paths": [
    {"path": "06-factions", "canonical": "04-factions"},
    {"path": "05-characters/npcs", "canonical": "05-npcs"},
    {"path": "10-adventures", "canonical": "10-adventures/available", "direct_files_only": true}
  ],
  "entity_types": {
    "character": {
      "template": "templates/character.md",
      "destination": "02-players/characters/{id}.md",
      "required_fields": ["id", "type", "status", "ownership", "name", "visibility", "warden_only"],
      "required_values": {"visibility": "warden", "warden_only": "true"}
    },
    "location": {
      "template": "templates/location.md", "destination": "03-world/locations/{id}.md",
      "required_fields": ["id", "type", "status", "ownership", "name", "visibility", "warden_only"],
      "required_values": {"visibility": "warden", "warden_only": "true"}
    },
    "system": {
      "template": "templates/system.md", "destination": "03-world/systems/{id}.md",
